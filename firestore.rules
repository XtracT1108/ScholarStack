rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: sessions
    // Document ID: sessionId
    // Fields:
    //   - uid: string (required) - Owner UID
    //   - name: string (required) - Session name
    //   - createdAt: timestamp (required) - Creation timestamp
    //   - factors: list (required) - List of factors being ranked
    //   - respondentData: list (required) - Raw ranking data
    //   - results: map (optional) - Calculated results
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isValidSession(data) {
      return data.keys().hasAll(['uid', 'name', 'createdAt', 'factors', 'respondentData']) &&
             data.uid is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.factors is list && data.factors.size() > 0 && data.factors.size() <= 20 &&
             data.respondentData is list && data.respondentData.size() <= 1000;
    }

    match /sessions/{sessionId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && 
                      request.resource.data.uid == request.auth.uid &&
                      isValidSession(request.resource.data);
      allow update: if isDocOwner() && 
                      request.resource.data.uid == resource.data.uid &&
                      isValidSession(request.resource.data);
      allow delete: if isDocOwner();
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }
  }
}
